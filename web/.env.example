# Copy to .env.local for local development (Next.js loads .env.local
# automatically and it is git-ignored). Never put secrets in NEXT_PUBLIC_*
# variables — anything with that prefix is bundled into client-side
# JavaScript and is visible to anyone who opens the page.

# Base URL of the AIWertPilot backend API (FastAPI). Must include the
# scheme and host, no trailing slash. Used by server-side reads (React
# Server Components fetch this directly, server-to-server, so it is public
# information — not a secret).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Development-only write controls (source creation, status transitions,
# blocking, rights decisions) are hidden and disabled unless this is
# exactly "true". This flag only controls UI visibility; the real
# authorization boundary is the backend's own X-API-Key check, performed
# server-side by this app's Server Actions (see src/lib/api/actions.ts) —
# never enable this against a shared or production backend.
NEXT_PUBLIC_ENABLE_DEV_WRITES=false

# The backend's development X-API-Key header value, required by every write
# endpoint. Only needed locally when NEXT_PUBLIC_ENABLE_DEV_WRITES=true.
# Deliberately NOT prefixed with NEXT_PUBLIC_: it is read only by this app's
# server-side Server Actions and is never sent to, or bundled into, the
# browser. See web/README.md "How the frontend talks to the backend".
DEV_API_KEY=change-me-dev-key
