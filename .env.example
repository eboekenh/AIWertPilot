# Copy to .env and adjust for your local environment. Never commit real secrets.

# Primary application database (async driver used by the API and services).
DATABASE_URL=postgresql+asyncpg://de_ai_kb:de_ai_kb@localhost:5432/de_ai_kb

# Sync URL used by Alembic (migrations run synchronously).
DATABASE_URL_SYNC=postgresql+psycopg://de_ai_kb:de_ai_kb@localhost:5432/de_ai_kb

# Dedicated database used only by the integration test suite. Must never point
# at a database containing real data — tests may truncate tables.
TEST_DATABASE_URL=postgresql+asyncpg://de_ai_kb:de_ai_kb@localhost:5432/de_ai_kb_test
TEST_DATABASE_URL_SYNC=postgresql+psycopg://de_ai_kb:de_ai_kb@localhost:5432/de_ai_kb_test

# Development-only write-route protection. Generate a random value locally;
# this is not a production authentication mechanism.
DEV_API_KEY=change-me-dev-key

# Local filesystem root used by the object-storage abstraction in this release.
OBJECT_STORAGE_LOCAL_ROOT=./.data/object-storage

# Structured logging level.
LOG_LEVEL=INFO
